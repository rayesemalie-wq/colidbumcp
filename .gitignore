# ColidbuMCP Website .gitignore
# Git 版本控制忽略文件

# 系统文件 System Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# Node modules (如果使用 npm)
node_modules/
package-lock.json
npm-debug.log*

# 编辑器临时文件 Editor Temporary Files
*.tmp
*.bak
*.backup
.#*

# 操作系统 OS Files
*.exe
*.dll
*.so
*.dylib

# 日志文件 Log Files
*.log
logs/

# 依赖项缓存 Dependency Cache
.cache/
vendor/

# 环境变量 Environment Variables
.env
.env.local
.env.*.local

# 构建输出 Build Output
dist/
build/
*.min.js
*.min.css

# 测试覆盖 Test Coverage
coverage/
.nyc_output/

# 临时文件 Temporary Files
tmp/
temp/
.tmp/

# IDE 文件 IDE Files
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.vscode/

# 本地配置 Local Configuration
config.local.js
local.json

# 私人文件 Private Files
secret/
private/
confidential/

# 已部署的文件 Deployed Files
*.dist
*.deployed

# macOS
.AppleDouble
.LSOverride

# Windows
$RECYCLE.BIN/
Desktop.ini
